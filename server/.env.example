# ============================================================
# Oncology Aid — Case Storage API 配置文件
# ============================================================
# 部署步骤：
#   1. cp server/.env.example server/.env
#   2. 按实际环境修改下方各值
#   3. 启动: cd server && uvicorn main:app --host 0.0.0.0 --port 8052
# ============================================================

# ── 数据库连接（必填） ──────────────────────────────────
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
# MySQL:     mysql+aiomysql://user:pass@host:3306/dbname
DATABASE_URL=postgresql+asyncpg://admin:CHANGE_ME@your_host:5432/oncology_aid

# ── CORS 允许的前端域名（逗号分隔） ─────────────────────
# 开发环境：http://localhost:5173
# 生产环境：https://your-hospital-domain.com
# allow_credentials=True 时不允许使用 "*"
CORS_ORIGINS=http://localhost:5173

# ── 鉴权模式 ──────────────────────────────────────────
# mock    — 所有请求视为同一用户（单机演示）
# header  — 读取 X-User-Id 请求头作为用户标识
# jwt     — 验证 Authorization: Bearer <token>
AUTH_MODE=mock
MOCK_USER_ID=default-user-001
# JWT_SECRET_KEY=your-secret-here    # 仅 AUTH_MODE=jwt 时需要
# JWT_ALGORITHM=HS256

# ── 速率限制 ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120        # 窗口内最大请求数
RATE_LIMIT_WINDOW=60           # 窗口秒数

# ── 数据库连接池 ──────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=10
DB_COMMAND_TIMEOUT=30

# ── 服务监听 ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8052
