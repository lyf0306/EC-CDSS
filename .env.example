# ── 前端环境变量 ─────────────────────────────────────────────────
# 复制此文件为 .env 并修改

# Pipeline API（FIGO 分期 / 患者画像 / MDT 方案生成）
VITE_API_BASE=http://localhost:8050

# EBM 循证搜索 API
VITE_EBM_BASE=http://localhost:8051

# Case Storage API（病例持久化）
# 留空则走 Vite proxy（开发时 proxy → localhost:8052）
# 生产环境填写完整 URL，如 http://your-server:8090
VITE_CASE_API_BASE=

# ── 后端环境变量 ─────────────────────────────────────────────────
# 参见 server/.env
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# HOST=0.0.0.0
# PORT=8090
